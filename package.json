{
  "name": "create-new-workspace",
  "version": "1.0.4",
  "description": "CLI tool to create a new workspace",
  "type": "module",
  "bin": {
    "cnw": "index.js",
    "create-new-workspace": "index.js"
  },
  "files": [
    "index.js",
    "src",
    "utils",
    "common",
    "resources",
    "public"
  ],
  "scripts": {
    "prepush": "pnpm format",
    "push": "pnpm version",
    "postpush": "pnpm backup && npm install -g && pnpm gitpush && echo Pushed new version",
    "format": "prettier --write \"./**/*.{js,json}\" --log-level silent",
    "backup": "node ./common/packages/backup",
    "gitpush": "git add . & git commit -m \"repo: misc update\" & git push"
  },
  "keywords": [],
  "author": "Jayant",
  "license": "ISC",
  "dependencies": {
    "@inquirer/prompts": "^3.3.0",
    "chalk": "^5.3.0",
    "fs-extra": "^11.1.1",
    "lodash": "^4.17.21",
    "nanospinner": "^1.1.0",
    "trash": "^8.1.1"
  },
  "devDependencies": {
    "prettier": "^3.0.3"
  }
}
